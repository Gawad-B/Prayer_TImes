{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": false,
    "skipLibCheck": true,
    "paths": {
      "gi://GLib": [
        "node_modules/@girs/glib-2.0"
      ],
      "gi://Gio": [
        "node_modules/@girs/gio-2.0"
      ],
      "gi://GObject": [
        "node_modules/@girs/gobject-2.0"
      ],
      "gi://St": [
        "node_modules/@girs/st-14"
      ],
      "gi://Clutter": [
        "node_modules/@girs/clutter-14"
      ],
      "gi://Geoclue": [
        "node_modules/@girs/geoclue-2.0"
      ],
      "gi://Gst": [
        "node_modules/@girs/gst-1.0"
      ],
      "gi://Adw": [
        "node_modules/@girs/adw-1"
      ],
      "gi://Gtk": [
        "node_modules/@girs/gtk-4.0"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}